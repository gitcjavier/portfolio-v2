---
import SqlServer from "./icons/SqlServer.astro";
import Photoshop from "./icons/Photoshop.astro";
import Tailwind from "./icons/Tailwind.astro";
import LinkButton from "./LinkButton.astro";
import GitHub from "./icons/GitHub.astro";
import Link from "./icons/Link.astro";
import Behance from "./icons/Behance.astro";
import Jumpseller from "./icons/Jumpseller.astro";
import CodeIcon from "./icons/Code.astro";
const TAGS = {
  PHOTOSHOP: {
    name: "Photoshop",
    class: "bg-black text-white",
    icon: Photoshop,
  },
  ILLUSTRATOR: {
    name: "Illustrator",
    class: "bg-black text-white",
    icon: "",
  },
  INDESIGN: {
    name: "InDesign",
    class: "bg-black text-white",
    icon: "",
  },
  SQL: {
    name: "SQL",
    class: "bg-black text-white",
    icon: SqlServer,
  },
  HTML: {
    name: "HTML",
    class: "bg-black text-white",
  },
  CSS: {
    name: "CSS",
    class: "bg-black text-white",
  },
  JAVASCRIPT: {
    name: "JavaScript",
    class: "bg-black text-white",
  },
  JUMPSELLER: {
    name: "Jumpseller",
    class: "bg-black text-white",
    icon: Jumpseller,
  },
};
const projects = [
  {
    title: "Poster Mob Psycho 100",
    description: "Poster para el anime Mob Psycho 100",
    image: "/img/projects/mob.png",
    link: "https://www.behance.net/gallery/227800757/Poster-Chigeo-Kageyama",
    tags: [TAGS.PHOTOSHOP],
    github: "",
  },
  {
    title: "Chetomi",
    description: "Ecommerce de Chetomi - Comida Argentina",
    image: "/img/projects/chetomiweb.webp",
    link: "https://www.chetomi.cl",
    tags: [TAGS.JUMPSELLER],
    github: "",
  },
];
import "../styles/global.css";
---

<style>
  .image-container {
    animation: reveal both;
    animation-timeline: view();
    animation-range: entry 20% cover 30%;
  }

  /* Optimizaciones específicas para iPhone 14 Pro y móviles similares */
  @media (max-width: 393px) {
    #projects {
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
      min-height: 100dvh;
    }
    
    #projects .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }
    
    #projects h2 {
      font-size: 1.75rem;
      padding-top: 0rem;
      padding-bottom: 0.5rem;
      margin-top: 0rem;
    }
    
    #projects article {
      padding: 1rem;
      gap: 1rem;
    }
    
    #projects h1 {
      font-size: 1.25rem;
      line-height: 1.3;
    }
    
    #projects .text-gray-400 {
      font-size: 0.875rem;
      line-height: 1.4;
    }
    
    #projects .flex-1 {
      gap: 1.5rem;
      padding-bottom: 1rem;
    }
    
    #projects .image-container {
      max-height: 12rem;
    }
    
    #projects img {
      max-height: 12rem;
      object-fit: cover;
    }
  }

  /* Mejoras adicionales para pantallas muy pequeñas */
  @media (max-width: 360px) {
    #projects h2 {
      font-size: 1.5rem;
    }
    
    #projects h1 {
      font-size: 1.125rem;
    }
  }
</style>
<section id="projects" class="min-h-screen bg-white dark:bg-gray-900 transition-colors duration-300 pt-16 flex flex-col justify-center lg:justify-center">
<div class="w-full flex flex-col lg:justify-center lg:items-center lg:min-h-screen lg:pt-0">
  <h2
    class="text-2xl xs:text-3xl sm:text-4xl dark:text-[#ccf381] text-[#ccf381] flex gap-x-2 xs:gap-x-4 mt-0 justify-center items-center fade-up image-container pt-0 pb-4 xs:pb-6 font-bold"
    style="animation-delay: 0.2s;"
  >
    <CodeIcon class="size-6 xs:size-7 sm:size-8" />
    Proyectos
  </h2>
  <div
    class="flex-1 flex flex-col gap-4 xs:gap-6 px-4 xs:px-6 pb-6 xs:pb-8 max-w-4xl mx-auto"
  >
    {
      projects.map(({ image, title, description, tags, link, github }) => (
        <article class="flex flex-col lg:flex-row gap-3 xs:gap-4 group bg-gray-900/50 dark:bg-gray-800/50 rounded-xl p-3 xs:p-4 hover:border-gray-700 hover:bg-gray-800/50 dark:hover:bg-gray-700/50 transition-all duration-300 image-container border border-gray-800/30">
          <div class="w-full lg:w-1/2 image-container">
            <div class="relative overflow-hidden rounded-lg image-container max-h-48 xs:max-h-56">
              <img
                alt={title}
                loading="lazy"
                src={image}
                class="w-full h-full object-cover transition-transform duration-500 lg:group-hover:scale-105"
              />
            </div>
          </div>

          <div class="w-full md:w-1/2 md:max-w-lg">
            <h1 class="text-lg xs:text-xl font-bold text-gray-100 mb-2">{title}</h1>
            <div class="flex flex-wrap mt-2">
              <ul class="flex flex-row mb-2 gap-x-2">
                {tags.map((tag) => (
                  <li>
                    <span
                      class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
                    >
                      <tag.icon class="size-3 xs:size-4 flex-shrink-0" />
                      {tag.name}
                    </span>
                  </li>
                ))}
              </ul>
              <div class="mb-3 mt-2 text-gray-400 text-sm xs:text-base leading-relaxed">{description}</div>
              <footer class="flex items-center mt-1 gap-4">
                {link && link.includes("behance") && (
                  <LinkButton href={link}>
                    <Behance class="size-5 xs:size-6" />
                    Behance
                  </LinkButton>
                )}
                {github && (
                  <LinkButton href={github}>
                    <GitHub class="size-5 xs:size-6" />
                    GitHub
                  </LinkButton>
                )}
                {link && !link.includes("behance") && (
                  <LinkButton href={link}>
                    <Link class="size-4 xs:size-4" />
                    Preview
                  </LinkButton>
                )}
              </footer>
          </div>
          </div>
        </article>
      ))
    }
  </div>
</div>
</section>
