---
import { ClientRouter } from "astro:transitions";
---

<style>
  .image-container {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease-out, transform 0.3s ease-out;
  }
  .image-container.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Ocultar tecnologías MacBook por defecto */
  .tech-macbook { display: none; }
  /* Mostrar solo en resoluciones MacBook y ocultar el default */
  @media (min-width: 1512px) and (max-width: 1512px) and (min-height: 982px) and (max-height: 982px) {
    .tech-macbook { display: flex; }
    .tech-default { display: none; }
  }

  /* Optimizaciones específicas para iPhone 14 Pro y móviles similares */
  @media (max-width: 393px) {
    #about {
      padding-top: 1rem;
      padding-bottom: 1rem;
      min-height: 100dvh;
    }
    
    #about .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }
    
    #about h2 {
      font-size: 1.75rem;
      margin-bottom: 1.5rem;
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
    }
    
    #about h1 {
      font-size: 1.875rem;
      line-height: 1.2;
      margin-bottom: 0.75rem;
    }
    
    #about p {
      font-size: 0.9rem;
      line-height: 1.5;
    }
    
    #about .flex.flex-col.lg\\:flex-row {
      gap: 1.5rem;
    }
    
    #about .mt-8 {
      margin-top: 1.5rem;
    }
    
    #about .pt-8 {
      padding-top: 1.5rem;
    }
    
    #about .gap-3 {
      gap: 0.75rem;
    }
    
    #about .grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
    }
    
    #about .glass-card {
      padding: 0.5rem;
    }
    
    #about .glass-card img {
      width: 1.75rem;
      height: 1.75rem;
    }
  }

  /* Mejoras adicionales para pantallas muy pequeñas */
  @media (max-width: 360px) {
    #about h2 {
      font-size: 1.5rem;
    }
    
    #about h1 {
      font-size: 1.625rem;
    }
    
    #about p {
      font-size: 0.875rem;
    }
  }
</style>

<section id="about" class="min-h-screen mobile-py bg-blue-600 dark:bg-blue-900 transition-colors duration-300 flex items-center">
  <div class="container mx-auto mobile-px">
    
      <h2 class="text-2xl xs:text-3xl sm:text-4xl font-bold mb-6 xs:mb-8 py-3 xs:py-5 text-center">
        <span class="text-[#ccf381]">/Self</span>
      </h2>
      
      <div class="flex flex-col items-start image-container animate-fade-in">
        <div class="flex flex-col lg:flex-row items-start gap-6 xs:gap-8 w-full animate-fade-in">
          <div class="w-full lg:w-1/2 opacity-0 animate-fade-in duration-1000" >
            <h1 class="text-white font-bold text-2xl xs:text-3xl sm:text-4xl lg:text-5xl image-container duration-1000 ease-in-out animate-fade-in mb-4">Diseño</h1>
            <p class="text-white text-base xs:text-lg leading-relaxed text-balance image-container animate-fade-in" style="animation-delay: 0.4s;">
              Soy un desarrollador Frontend apasionado por crear experiencias web excepcionales. 
              Me especializo en tecnologías modernas y me mantengo constantemente actualizado con las últimas tendencias en desarrollo web.
            </p>
          </div>
          <div class="flex-shrink-0 hidden lg:block">
            <svg xmlns="http://www.w3.org/2000/svg" width="200" height="120" viewBox="0 0 325 193" data-shape="true" aria-hidden="true" id="cs-pattern-left"><path fill="none" stroke="#ffffff" stroke-miterlimit="50" stroke-width="2" d="M17.053 9.57a7.891 7.891 0 11-15.782 0 7.891 7.891 0 0115.782 0zM45.122 9.57a7.891 7.891 0 11-15.782 0 7.891 7.891 0 0115.782 0zM73.19 9.57a7.891 7.891 0 11-15.781 0 7.891 7.891 0 0115.782 0zM101.26 9.57a7.891 7.891 0 11-15.782 0 7.891 7.891 0 0115.782 0zM129.329 9.57a7.891 7.891 0 11-15.783 0 7.891 7.891 0 0115.783 0zM238.083 103.963v0l-.561 22.259v0l22.259-.561v0l-.561 22.258v0l22.259-.56v0l-.561 22.258v0l22.259-.56v0l-.559 22.26v0l22.26-.56v0"></path>
            </svg>
          </div>
        </div>       
        <div class="w-full lg:w-1/2 lg:self-end opacity-0 animate-fade-in duration-1000 image-container mt-8 lg:mt-0" style="animation-delay: 0.4s;">
          <h1 class="text-white font-bold text-2xl xs:text-3xl sm:text-4xl lg:text-5xl image-container duration-1000 ease-in-out animate-fade-in mb-4">Ingeniería</h1>
          <p class="text-white text-base xs:text-lg leading-relaxed image-container duration-1000 ease-in-out animate-fade-in"  style="animation-delay: 0.2s;">
            Mi enfoque se centra en escribir código limpio y mantenible, 
            crear interfaces intuitivas y asegurar que cada proyecto cumpla 
            con los más altos estándares de calidad y rendimiento.
          </p>
        </div>
      </div>

          <!-- Tecnologías solo visible en MacBook -->
           
      <div class="flex flex-col xs:flex-row items-center xs:items-end justify-center pt-8 xs:pt-10 xs:justify-start gap-3 xs:gap-4 z-50">
            <a 
              target="_blank"
              role="link"
              href="/resume.pdf" 
              class="relative inline-flex items-center justify-center gap-2 px-5 xs:px-6 py-3.5 text-white border border-white bg-transparent transition-all duration-300 ease-in-out overflow-hidden group hover:text-blue-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 w-full xs:w-auto text-center text-sm xs:text-base font-medium"
            >
              <span class="absolute inset-0 bg-white transform -translate-x-full transition-transform duration-300 ease-in-out group-hover:translate-x-0"></span>
              <span class="relative z-10">Descargar CV</span>
            </a>
            <a
              transition:animate="none"
              transition:name="experiences"
              role="link"
              href="/experiences" 
              id="experience-btn"
              class="relative inline-flex items-center justify-center gap-2 px-5 xs:px-6 py-3.5 text-white border border-white bg-transparent transition-all duration-300 ease-in-out overflow-hidden group hover:text-blue-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 w-full xs:w-auto text-center text-sm xs:text-base font-medium"
            >
              <span class="absolute inset-0 bg-white transform -translate-x-full transition-transform duration-300 ease-in-out group-hover:translate-x-0"></span>
              <span class="relative z-10">💼 Experiencia Laboral</span>
            </a>
      </div>
        
        <!-- Sección original de tecnologías para otras resoluciones -->
        <div class="tech-default skills-section opacity-0 animate-fade-in duration-500 delay-100 mt-8 xs:mt-10 image-container">
          <h3 class="text-xl xs:text-2xl font-semibold text-white mb-6 items-center justify-center flex">Tecnologías</h3>

          <div class="grid grid-cols-3 xs:grid-cols-4 sm:grid-cols-5 md:grid-cols-6 lg:grid-cols-6 gap-3 xs:gap-4">
            <div class="glass-card group transform transition-transform duration-300 hover:scale-110">
              <img src="/icons/Astro_dark.svg" alt="Astro" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-300 group-hover:scale-110" />
            </div>
            <div class="glass-card group transform transition-transform duration-300 hover:scale-110">
              <img src="/icons/tailwindcss.svg" alt="Tailwind CSS" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-300 group-hover:scale-110" />
            </div>
            <div class="glass-card group transform transition-transform duration-300 hover:scale-110">
              <img src="/icons/css3.svg" alt="CSS3" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-300 group-hover:scale-110" />
            </div>
            <div class="glass-card group transform transition-transform duration-300 hover:scale-110">
              <img src="/icons/html5.svg" alt="HTML5" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-300 group-hover:scale-110" />
            </div>
            <div class="glass-card group transform transition-transform duration-300 hover:scale-110">
              <img src="/icons/javascript.svg" alt="JavaScript" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-300 group-hover:scale-110" />
            </div>
            <div class="glass-card group transform transition-transform duration-300 hover:scale-110">
              <img src="/icons/supabase.svg" alt="Supabase" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-300 group-hover:scale-110" />
            </div>
            <div class="glass-card group transform transition-transform duration-300 hover:scale-110">
              <img src="/icons/git.svg" alt="Git" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-300 group-hover:scale-110" />
            </div>
            <div class="glass-card group transform transition-transform duration-300 hover:scale-110">
              <img src="/icons/github.svg" alt="GitHub" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-300 group-hover:scale-110" />
            </div>
            <div class="glass-card group transform transition-transform duration-300 hover:scale-110">
              <img src="/icons/photoshop.svg" alt="Photoshop" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-300 group-hover:scale-110" />
            </div>
            <div class="glass-card group transform transition-transform duration-300 hover:scale-110">
              <img src="/icons/illustrator.svg" alt="Illustrator" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-300 group-hover:scale-110" />
            </div>
            <div class="glass-card group transform transition-transform duration-100 hover:scale-110">
              <img src="/icons/lightroom.svg" alt="Lightroom" class="w-8 h-8 xs:w-10 xs:h-10 sm:w-12 sm:h-12 transition-transform duration-100 hover:scale-110" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Intersection Observer para animar elementos cada vez que entran/salen del viewport
  const observerOptions = {
    threshold: 0.5,
    rootMargin: '0px 0px -300px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      } else {
        entry.target.classList.remove('visible');
      }
    });
  }, observerOptions);

  // Observar todos los elementos con clase image-container
  document.addEventListener('DOMContentLoaded', () => {
    const imageContainers = document.querySelectorAll('.image-container');
    imageContainers.forEach(container => {
      observer.observe(container);
    });
  });
</script>
